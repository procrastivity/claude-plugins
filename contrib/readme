#!/usr/bin/env bash
set -Eeuo pipefail

DIR=$(cd "$(dirname "${0}")" && pwd)
PROJECT_ROOT=$(cd "$DIR/.." && pwd)
cd "$PROJECT_ROOT"

MARKETPLACE=".claude-plugin/marketplace.json"
README="README.md"
MANIFEST_PATH=".claude-plugin/plugin.json"

# Markers delimiting the generated plugin table inside README.md.
BEGIN_MARKER="<!-- BEGIN PLUGINS (generated by contrib/readme — do not edit) -->"
END_MARKER="<!-- END PLUGINS -->"

usage() {
  cat <<EOF
Usage: contrib/readme [--check]

Reads ${MARKETPLACE}, fetches each plugin's canonical .claude-plugin/plugin.json
from GitHub (via 'gh api'), syncs the marketplace descriptions to match, and
regenerates ${README} (intro, install instructions, and a generated plugin table).

  (no args)   Sync ${MARKETPLACE} and write ${README}.
  --check     Dry run for CI: write nothing; exit non-zero (and print a diff)
              if ${MARKETPLACE} or ${README} is out of date, or a fetch fails.
EOF
  exit "${1:-1}"
}

# --- Parse arguments ---

CHECK=0
case "${1:-}" in
"") ;;
--check) CHECK=1 ;;
-h | --help) usage 0 ;;
*) usage ;;
esac

# --- Preconditions ---

for tool in jq gh; do
  command -v "$tool" >/dev/null || {
    echo "error: '$tool' not found on PATH." >&2
    exit 1
  }
done

if ! gh auth status >/dev/null 2>&1; then
  echo "error: 'gh' is not authenticated; run 'gh auth login'." >&2
  exit 1
fi

# --- Read the marketplace manifest ---

MARKET_NAME=$(jq -r '.name' "$MARKETPLACE")
PLUGIN_COUNT=$(jq '.plugins | length' "$MARKETPLACE")

# The GitHub path users add as a marketplace ('owner/repo') is this repo's slug,
# which is independent of the marketplace 'name'. Derive it (works locally and in
# CI) rather than hardcoding, so a fork or rename stays correct.
MARKET_REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "${GITHUB_REPOSITORY:-}")
if [[ -z "$MARKET_REPO" ]]; then
  echo "error: could not determine this repository's owner/name ('gh repo view' failed and GITHUB_REPOSITORY is unset)." >&2
  exit 1
fi

# Working copy of the marketplace JSON; we apply synced descriptions to it and
# only persist (or diff) at the end.
new_marketplace=$(cat "$MARKETPLACE")

# Parallel arrays of the per-plugin facts needed to render the README table.
declare -a ROW_DISPLAY ROW_DESC ROW_VERSION ROW_REPO

fetch_failed=0

for ((i = 0; i < PLUGIN_COUNT; i++)); do
  mname=$(jq -r --argjson i "$i" '.plugins[$i].name' "$MARKETPLACE")
  repo=$(jq -r --argjson i "$i" '.plugins[$i].source.repo' "$MARKETPLACE")

  echo "Fetching ${repo} (${MANIFEST_PATH})..." >&2

  # Raw accept header returns the file contents directly (no base64 decode).
  if ! manifest=$(gh api "repos/${repo}/contents/${MANIFEST_PATH}" \
    -H "Accept: application/vnd.github.raw" 2>/dev/null); then
    echo "error: could not fetch ${MANIFEST_PATH} from '${repo}' (missing file, private repo, or wrong source.repo)." >&2
    fetch_failed=1
    continue
  fi

  pname=$(jq -r '.name' <<<"$manifest")
  pdisplay=$(jq -r '.displayName // .name' <<<"$manifest")
  pdesc=$(jq -r '.description // ""' <<<"$manifest")
  pversion=$(jq -r '.version // ""' <<<"$manifest")

  # The plugin manifest is canonical; its name must match the marketplace entry.
  if [[ "$pname" != "$mname" ]]; then
    echo "error: ${repo}'s plugin.json name '${pname}' does not match marketplace entry '${mname}' (check source.repo)." >&2
    fetch_failed=1
    continue
  fi

  # Sync the canonical description into the working marketplace copy.
  new_marketplace=$(jq --argjson i "$i" --arg d "$pdesc" \
    '.plugins[$i].description = $d' <<<"$new_marketplace")

  ROW_DISPLAY[i]="$pdisplay"
  ROW_DESC[i]="$pdesc"
  ROW_VERSION[i]="$pversion"
  ROW_REPO[i]="$repo"
done

if [[ "$fetch_failed" -eq 1 ]]; then
  echo "error: one or more plugins could not be resolved; aborting." >&2
  exit 1
fi

# --- Render the README ---

# Escape a value for use inside a Markdown table cell: collapse newlines to
# spaces and escape pipes so upstream text can't break the column layout.
md_cell() {
  local s=$1
  s=${s//$'\n'/ }
  s=${s//|/\\|}
  printf '%s' "$s"
}

render_readme() {
  cat <<EOF
# ${MARKET_NAME}

A [Claude Code](https://docs.claude.com/en/docs/claude-code) plugin marketplace.

## Installation

Add this marketplace to Claude Code, then install any plugin from the list below:

\`\`\`
/plugin marketplace add ${MARKET_REPO}
/plugin install <plugin-name>@${MARKET_NAME}
\`\`\`

## Plugins

${BEGIN_MARKER}
| Plugin | Description | Version |
| ------ | ----------- | ------- |
EOF

  for ((i = 0; i < PLUGIN_COUNT; i++)); do
    local display="${ROW_DISPLAY[i]}"
    local desc="${ROW_DESC[i]}"
    local version="${ROW_VERSION[i]}"
    local repo="${ROW_REPO[i]}"
    printf '| [%s](https://github.com/%s) | %s | %s |\n' \
      "$(md_cell "$display")" "$repo" "$(md_cell "$desc")" "${version:+v$version}"
  done

  cat <<EOF
${END_MARKER}

## Contributing

Plugin entries are defined in [\`${MARKETPLACE}\`](${MARKETPLACE}). Each plugin's
name, description, and version are sourced from its own \`${MANIFEST_PATH}\`; this
\`README.md\` and the descriptions in \`${MARKETPLACE}\` are generated by
[\`contrib/readme\`](contrib/readme). After adding or changing a plugin entry, run:

\`\`\`
contrib/readme
\`\`\`

## License

See [LICENSE](LICENSE).
EOF
}

new_readme=$(render_readme)

# --- Persist or check ---

if [[ "$CHECK" -eq 1 ]]; then
  stale=0
  if ! diff -u "$MARKETPLACE" <(printf '%s\n' "$new_marketplace") >/tmp/.readme-mp.diff 2>/dev/null; then
    echo "error: ${MARKETPLACE} is out of date:" >&2
    cat /tmp/.readme-mp.diff >&2
    stale=1
  fi
  if [[ ! -f "$README" ]]; then
    echo "error: ${README} does not exist; run 'contrib/readme' to generate it." >&2
    stale=1
  elif ! diff -u "$README" <(printf '%s\n' "$new_readme") >/tmp/.readme-rm.diff 2>/dev/null; then
    echo "error: ${README} is out of date:" >&2
    cat /tmp/.readme-rm.diff >&2
    stale=1
  fi
  rm -f /tmp/.readme-mp.diff /tmp/.readme-rm.diff
  if [[ "$stale" -eq 1 ]]; then
    echo "Run 'contrib/readme' to regenerate." >&2
    exit 1
  fi
  echo "Up to date."
  exit 0
fi

# Safe writes: temp + mv so an interrupted write can't truncate the targets.
tmp_mp=$(mktemp)
printf '%s\n' "$new_marketplace" >"$tmp_mp"
if ! diff -q "$MARKETPLACE" "$tmp_mp" >/dev/null 2>&1; then
  mv "$tmp_mp" "$MARKETPLACE"
  echo "Updated ${MARKETPLACE} (synced descriptions from plugin manifests)."
else
  rm -f "$tmp_mp"
fi

tmp_rm=$(mktemp)
printf '%s\n' "$new_readme" >"$tmp_rm"
if [[ ! -f "$README" ]] || ! diff -q "$README" "$tmp_rm" >/dev/null 2>&1; then
  mv "$tmp_rm" "$README"
  echo "Updated ${README}."
else
  rm -f "$tmp_rm"
fi

echo "Done."
